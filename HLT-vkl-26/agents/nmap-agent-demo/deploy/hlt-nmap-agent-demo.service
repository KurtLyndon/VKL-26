[Unit]
Description=HLT Nmap Agent Demo
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/hlt/nmap-agent-demo
EnvironmentFile=/opt/hlt/nmap-agent-demo/.env
ExecStart=/opt/hlt/nmap-agent-demo/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8081
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

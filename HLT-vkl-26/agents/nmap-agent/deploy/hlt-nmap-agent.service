[Unit]
Description=HLT Nmap Agent
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/hlt/nmap-agent
EnvironmentFile=/opt/hlt/nmap-agent/.env
ExecStart=/opt/hlt/nmap-agent/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8081
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
